generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int     @id
  password       String
  name           String?
  current_course String?
}

model WritingExam {
  id             Int             @id @default(autoincrement())
  studentId      Int             @unique
  text           String
  createdAt      DateTime        @default(now())
  cheatingEvents CheatingEvent[]
}

model CheatingEvent {
  id        Int         @id @default(autoincrement())
  examId    Int
  eventType String
  timestamp DateTime    @default(now())
  metadata  Json?
  exam      WritingExam @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model WritingLog {
  id        Int      @id @default(autoincrement())
  studentId Int
  event     String
  data      String?
  suspected Boolean? @default(false)
  createdAt DateTime @default(now())

  @@index([studentId, id])
}

model ExternalStudent {
  id        String   @id   // "n1", "n2", etc.
  password  String
  name      String
  createdAt DateTime @default(now())

  exams     ExternalWritingExam[]
  logs      ExternalWritingLog[]
}

model ExternalWritingExam {
  id               Int       @id @default(autoincrement())

  studentId        String @unique
  student          ExternalStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)

  startedAt        DateTime  @default(now())
  durationMinutes  Int
  submittedAt      DateTime?
  expired          Boolean   @default(false)
  submittedBy      String?

  textFinal        String?
  wordCount        Int?
  charCount        Int?
  suspicionScore   Int?

  cheatingEvents   ExternalCheatingEvent[]

  createdAt        DateTime  @default(now())
}

model ExternalAdmin {
  id        String   @id
  password  String
  name      String
  createdAt DateTime @default(now())
}

model ExternalCheatingEvent {
  id        Int      @id @default(autoincrement())
  examId    Int
  eventType String
  timestamp DateTime @default(now())
  metadata  Json?

  exam ExternalWritingExam @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model ExternalWritingLog {
  id        Int      @id @default(autoincrement())
  studentId String
  event     String
  data      String?
  suspected Boolean? @default(false)
  createdAt DateTime @default(now())

  student ExternalStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, id])
}

model StudentWork {
  id         String   @id
  studentId  String
  title      String?
  fileUrl    String
  fileHash   String
  createdAt  DateTime @default(now())
}

model ConsentPublication {
  id         Int      @id @default(autoincrement())
  studentId  String
  workId     String
  workTitle  String?
  name       String

  fileHash   String

  ip         String?
  userAgent  String?

  createdAt  DateTime @default(now())

  @@unique([studentId, workId])
}
